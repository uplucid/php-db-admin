# Copy to .env and fill in values. .env is gitignored.
# docker-compose.yml loads this file via env_file.

# --- DB login-form prefill (optional) ------------------------
DB_DRIVER=    # eg. mysql, pgsql, sqlite
DB_HOST=    
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PATH=

# --- AI SQL generation (optional) ----------------------------
OPENAI_API_KEY=    # eg. sk-xxxx (get from https://platform.openai.com/account/api-keys)
OPENAI_BASE_URL=    # eg. https://api.openai.com/v1
OPENAI_MODEL=    # eg. gpt-5.4-mini
